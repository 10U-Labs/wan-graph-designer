        <color>ff999999</color>
        <scale>0.85</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/shapes/placemark_circle.png</href>
        </Icon>
      </IconStyle>
    </Style>
    <Style id="edge_access">
      <LineStyle>
        <color>ff25a8f9</color>
        <width>1.4</width>
      </LineStyle>
    </Style>
    <Style id="edge_physical">
      <LineStyle>
        <color>ff333333</color>
        <width>2.2</width>
      </LineStyle>
    </Style>
