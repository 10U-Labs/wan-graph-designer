    <Style id="node_access">
      <IconStyle>
        <color>ff25a8f9</color>
        <scale>0.85</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/shapes/placemark_circle.png</href>
        </Icon>
      </IconStyle>
    </Style>
    <Style id="node_aggregation">
      <IconStyle>
